meta {
  name: Testuser blocked on /anything
  type: http
  seq: 4
}

get {
  url: {{testuserBaseUrl}}/anything
}

headers {
  accept: application/json
}

tests {
  test("status is 403", function() {
    expect(res.getStatus()).to.equal(403);
  });

  test("has message body", function() {
    expect(res.getBody()).to.have.property("message");
  });
}
