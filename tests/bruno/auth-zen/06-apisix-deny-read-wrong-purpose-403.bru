meta {
  name: [APISIX] deny BRP read for marketing purpose
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/authzen/brp
  body: json
  auth: none
}

headers {
  content-type: application/json
  accept: application/json
  x-request-id: req-rotterdam-20260512-0002
}

body:json {
  {
    "case_id": "ROT-CASE-2026-0043",
    "citizen": {
      "bsn": "999991234"
    },
    "requested_field": ["residential_address"],
    "token": "trace-rotterdam-20260512-0002",
    "business_reason": "targeted-marketing-campaign",
    "authorization": {
      "action": "read",
      "subject": {
        "type": "service-account",
        "id": "municipality-case-api",
        "organization": "urn:nl:gov:rotterdam",
        "assurance_level": "substantial",
        "roles": ["municipality_caseworker"],
        "scopes": ["brp:read"]
      },
      "resource": {
        "type": "brp-record",
        "id": "bsn:999991234",
        "sensitivity": "high"
      },
      "context": {
        "purpose": "marketing",
        "channel": "mtls",
        "loa": "substantial"
      }
    }
  }
}

tests {
  test("status is 403 - policy agent denied the request", function() {
    expect(res.getStatus()).to.equal(403);
  });

  test("policy denial includes purpose-related context", function() {
    const body = res.getBody();
    expect(body).to.have.property("reason_admin");
    expect(body.reason_admin).to.have.property("403");
    expect(body.reason_admin["403"]).to.contain("purpose");
    expect(body).to.have.property("reason_user");
    expect(body.reason_user).to.have.property("403");
  });
}

docs {
  Real-world deny scenario: BRP access requested for a marketing use case.
  The route is configured with a non-allowed purpose and must return 403 with
  policy context explaining the denial.
}
