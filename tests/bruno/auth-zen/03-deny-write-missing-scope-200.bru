meta {
  name: deny BRP write without brp:write scope
  type: http
  seq: 3
}

post {
  url: {{authzenBaseUrl}}/access/v1/evaluation
  body: json
  auth: none
}

headers {
  content-type: application/json
  accept: application/json
}

body:json {
  {
    "input": {
      "subject": {
        "type": "service-account",
        "id": "municipality-case-api",
        "properties": {
          "organization": "urn:nl:gov:rotterdam",
          "assurance_level": "high",
          "roles": ["municipality_caseworker"],
          "scopes": ["brp:read"]
        }
      },
      "resource": {
        "type": "brp-record",
        "id": "bsn:999991234",
        "properties": {
          "sensitivity": "high"
        }
      },
      "action": {
        "name": "write"
      },
      "context": {
        "purpose": "uitvoering-wettelijke-taak",
        "channel": "mtls",
        "loa": "high",
        "time": "2026-05-11T11:02:00Z",
        "traceparent": "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01",
        "tracestate": "congo=t61rcWkgMzE",
        "mim": "https://example.org/mim/authzen/v1",
        "ld-context": "https://example.org/contexts/authzen-v1.jsonld"
      }
    }
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("decision is deny for missing write scope", function() {
    const body = res.getBody();
    expect(body).to.have.property("decision", false);
    expect(body).to.have.property("context");
    expect(body.context).to.have.property("reason_admin");
    expect(body.context.reason_admin).to.have.property("403");
    expect(body.context.reason_admin["403"]).to.contain("write");
  });
}

docs {
  NOTE: This test calls the AuthZEN policy agent (OPA) directly — it does NOT test the APISIX auth-zen plugin.
  Its purpose is to verify that the policy logic itself is correct before the plugin integration is tested.
  See tests 05–09 for expected APISIX plugin behaviour.
}
