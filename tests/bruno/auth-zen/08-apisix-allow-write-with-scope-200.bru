  content-type: application/json
  accept: application/json
  authorization: Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJtdW5pY2lwYWxpdHktY2FzZS1hcGkiLCJvcmdhbml6YXRpb24iOiJ1cm46bmw6Z292OnJvdHRlcmRhbSIsImFzc3VyYW5jZV9sZXZlbCI6ImhpZ2giLCJyb2xlcyI6WyJtdW5pY2lwYWxpdHlfY2FzZXdvcmtlciJdLCJzY29wZXMiOlsiYnJwOnJlYWQiLCJicnA6d3JpdGUiXX0.signature-placeholder
