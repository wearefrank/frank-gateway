  accept: application/json
  authorization: Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJtdW5pY2lwYWxpdHktY2FzZS1hcGkiLCJvcmdhbml6YXRpb24iOiJ1cm46bmw6Z292OnJvdHRlcmRhbSIsImFzc3VyYW5jZV9sZXZlbCI6InN1YnN0YW50aWFsIiwicm9sZXMiOlsibXVuaWNpcGFsaXR5X2Nhc2V3b3JrZXIiXSwic2NvcGVzIjpbImJycDpyZWFkIl19.signature-placeholder
