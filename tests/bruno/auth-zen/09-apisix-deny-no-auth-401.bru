meta {
  name: [APISIX] deny request - no Authorization header
  type: http
  seq: 9
}

docs {
  This test targets /authzen/no-auth, a route protected with key-auth in
  tests/auth-zen/apisix-standalone-config.yaml.
  No API key is sent, so APISIX must return 401.
}

get {
  url: {{baseUrl}}/authzen/no-auth
  body: none
}

headers {
  accept: application/json
}

tests {
  test("status is 401 - no credentials provided", function() {
    expect(res.getStatus()).to.equal(401);
  });
}
