meta {
  name: correct credentials returns 200 with Bearer token
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/any/jwt-correct
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("upstream receives Authorization header", function() {
    const body = res.getBody();
    expect(body).to.have.property("headers");
    expect(body.headers).to.have.property("Authorization");
    expect(body.headers.Authorization).to.match(/^Bearer /);
  });
}
