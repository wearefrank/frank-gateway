meta {
  name: consumer1 routes to Consumer 1
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/frank-sender
}

headers {
  consumer: consumer1
  accept: application/json
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("frank payload is Consumer 1!", function() {
    const body = res.getBody();
    expect(body).to.have.property("data");
    expect(body.data).to.equal("Consumer 1!");
  });
}