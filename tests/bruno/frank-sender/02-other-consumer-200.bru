meta {
  name: non-matching consumer routes to fallback
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/frank-sender
}

headers {
  consumer: nope
  accept: application/json
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("frank payload is Not consumer 1!", function() {
    const body = res.getBody();
    expect(body).to.have.property("data");
    expect(body.data).to.equal("Not consumer 1!");
  });
}