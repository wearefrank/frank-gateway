meta {
  name: No cert blocked on /anything
  type: http
  seq: 7
}

get {
  url: {{noCertBaseUrl}}/anything
}

headers {
  accept: application/json
}

tests {
  test("status is 401", function() {
    expect(res.getStatus()).to.equal(401);
  });

  test("message indicates cert is required", function() {
    const body = res.getBody();
    expect(body).to.have.property("message");
    expect(String(body.message)).to.include("Client certificate required");
  });
}
