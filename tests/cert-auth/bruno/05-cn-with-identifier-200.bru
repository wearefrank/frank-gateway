meta {
  name: CN with identifier can call /test-cn-with-identifier
  type: http
  seq: 5
}

get {
  url: {{certuserBaseUrl}}/test-cn-with-identifier
}

headers {
  accept: application/json
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("consumer header is certuser", function() {
    const body = res.getBody();
    const headers = (body && body.headers) || {};
    const consumer = headers["X-Consumer-Username"] || headers["x-consumer-username"];
    expect(consumer).to.equal("certuser");
  });
}
