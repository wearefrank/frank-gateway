<Configuration name="test-frank" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../FrankConfig.xsd">
	<Adapter name="HeaderBasedRoutingAdapter">
		<Receiver name="HeaderBasedReceiver">
			<ApiListener
				name="HeaderBasedApiListener"
				uriPattern="frank-test"
				methods="GET, PUT, POST, PATCH, DELETE, HEAD"
				headerParams="consumer"/>
		</Receiver>


		<Pipeline firstPipe="ExtractConsumerHeader">
			<XsltPipe
				name="ExtractConsumerHeader"
				getInputFromFixedValue="&lt;dummy/&gt;"
				xpathExpression="$consumer"
				storeResultInSessionKey="consumerHeader">
				<Param name="consumer" sessionKey="headers" xpathExpression="/headers/header[@name='consumer']/text()"/>
				<Forward name="success" path="RoutingPipe"/>
			</XsltPipe>

			<!-- Route based on the 'consumer' header value -->
			<IfPipe name="RoutingPipe"
					getInputFromSessionKey="consumerHeader"
					expressionValue="consumer1">
				<Forward name="then" path="Consumer1Process" />
				<Forward name="else" path="NoConsumerProcess" />
			</IfPipe>

			<!-- Process for consumer1 -->
			<EchoPipe name="Consumer1Process" getInputFromFixedValue="Consumer 1!">
				<Forward name="success" path="READY"/>
			</EchoPipe>

			<!-- Process for any other consumer -->
			<EchoPipe name="NoConsumerProcess" getInputFromFixedValue="Not consumer 1!">
				<Forward name="success" path="READY"/>
			</EchoPipe>
		</Pipeline>
	</Adapter>
</Configuration>